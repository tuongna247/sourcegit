<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SourceGit.ViewModels"
             x:Class="SourceGit.Views.TerminalPanel"
             x:DataType="vm:TerminalSession">

  <Grid RowDefinitions="*,Auto">

    <!-- Output Area -->
    <Border Grid.Row="0"
            Background="{DynamicResource Brush.Contents}"
            BorderBrush="{DynamicResource Brush.Border0}"
            BorderThickness="0,0,0,1">
      <ScrollViewer x:Name="OutputScroll"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
        <SelectableTextBlock x:Name="OutputText"
                             Text="{Binding Output}"
                             FontFamily="{DynamicResource Fonts.Monospace}"
                             FontSize="12"
                             Margin="8"
                             Foreground="{DynamicResource Brush.FG1}"
                             TextWrapping="NoWrap"/>
      </ScrollViewer>
    </Border>

    <!-- Input Area -->
    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto"
          Background="{DynamicResource Brush.ToolBar}"
          Height="36">

      <TextBlock Grid.Column="0"
                 Text=">"
                 FontFamily="{DynamicResource Fonts.Monospace}"
                 FontSize="13"
                 FontWeight="Bold"
                 Foreground="{DynamicResource Brush.Accent}"
                 VerticalAlignment="Center"
                 Margin="10,0,6,0"/>

      <TextBox Grid.Column="1"
               x:Name="InputBox"
               Text="{Binding InputLine, Mode=TwoWay}"
               FontFamily="{DynamicResource Fonts.Monospace}"
               FontSize="12"
               BorderThickness="0"
               Background="Transparent"
               VerticalAlignment="Center"
               KeyDown="OnInputKeyDown"
               Watermark="Enter command..."/>

      <Button Grid.Column="2"
              Classes="icon_button"
              Width="28" Height="28"
              Click="OnClearClicked"
              ToolTip.Tip="Clear output"
              Margin="2,0">
        <Path Width="11" Height="11" Data="{StaticResource Icons.Clean}" Fill="{DynamicResource Brush.FG2}"/>
      </Button>

      <Button Grid.Column="3"
              Classes="icon_button"
              Width="28" Height="28"
              Click="OnRestartClicked"
              ToolTip.Tip="Restart shell"
              Margin="0,0,4,0">
        <Path Width="11" Height="11" Data="{StaticResource Icons.Refresh}" Fill="{DynamicResource Brush.FG2}"/>
      </Button>

    </Grid>
  </Grid>
</UserControl>
