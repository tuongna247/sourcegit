<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SourceGit.ViewModels"
             xmlns:m="using:SourceGit.Models"
             xmlns:c="using:SourceGit.Converters"
             x:Class="SourceGit.Views.PullRequestsPage"
             x:DataType="vm:PullRequestsPage">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Header -->
    <Border Grid.Row="0"
            Background="{DynamicResource Brush.ToolBar}"
            BorderBrush="{DynamicResource Brush.Border0}"
            BorderThickness="0,0,0,1"
            Height="36">
      <Grid ColumnDefinitions="*,Auto,Auto" Margin="8,0">
        <TextBlock Grid.Column="0"
                   Text="{Binding PlatformLabel}"
                   FontSize="12"
                   FontWeight="Bold"
                   Foreground="{DynamicResource Brush.FG2}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"/>

        <TextBlock Grid.Column="1"
                   Text="{Binding StatusMessage}"
                   FontSize="11"
                   Foreground="{DynamicResource Brush.FG2}"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0"
                   IsVisible="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}"/>

        <Button Grid.Column="2"
                Classes="icon_button"
                Width="28" Height="28"
                Click="OnRefreshClicked"
                IsEnabled="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}"
                ToolTip.Tip="Refresh pull requests">
          <Path Width="11" Height="11" Data="{StaticResource Icons.Refresh}" Fill="{DynamicResource Brush.FG1}"/>
        </Button>
      </Grid>
    </Border>

    <!-- PR List -->
    <ListBox Grid.Row="1"
             ItemsSource="{Binding PullRequests}"
             SelectedItem="{Binding SelectedPR, Mode=TwoWay}"
             Background="{DynamicResource Brush.Contents}"
             BorderThickness="0">
      <ListBox.ItemTemplate>
        <DataTemplate DataType="m:PullRequest">
          <Border Padding="8,6" DoubleTapped="OnPRDoubleTapped">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">

              <!-- Title -->
              <TextBlock Grid.Row="0" Grid.Column="0"
                         Text="{Binding Title}"
                         FontSize="13"
                         Foreground="{DynamicResource Brush.FG1}"
                         TextTrimming="CharacterEllipsis"/>

              <!-- PR number -->
              <Border Grid.Row="0" Grid.Column="1"
                      Height="16" Padding="6,0"
                      CornerRadius="8"
                      Background="{DynamicResource Brush.Badge}"
                      Margin="4,0,0,0"
                      VerticalAlignment="Center">
                <TextBlock Text="{Binding Number, StringFormat='#{0}'}"
                           FontSize="10"
                           FontFamily="{DynamicResource Fonts.Monospace}"
                           Foreground="{DynamicResource Brush.BadgeFG}"/>
              </Border>

              <!-- Branch info -->
              <StackPanel Grid.Row="1" Grid.ColumnSpan="2"
                          Orientation="Horizontal"
                          Margin="0,3,0,0">
                <TextBlock Text="{Binding Author}"
                           FontSize="11"
                           Foreground="{DynamicResource Brush.FG2}"/>
                <TextBlock Text="  "
                           FontSize="11"
                           Foreground="{DynamicResource Brush.FG2}"/>
                <TextBlock Text="{Binding SourceBranch}"
                           FontSize="11"
                           FontFamily="{DynamicResource Fonts.Monospace}"
                           Foreground="{DynamicResource Brush.Accent}"/>
                <TextBlock Text=" → "
                           FontSize="11"
                           Foreground="{DynamicResource Brush.FG2}"/>
                <TextBlock Text="{Binding TargetBranch}"
                           FontSize="11"
                           FontFamily="{DynamicResource Fonts.Monospace}"
                           Foreground="{DynamicResource Brush.FG2}"/>
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- Footer hint -->
    <Border Grid.Row="2"
            Background="{DynamicResource Brush.ToolBar}"
            BorderBrush="{DynamicResource Brush.Border0}"
            BorderThickness="0,1,0,0"
            Height="24"
            IsVisible="{Binding PullRequests.Count, Converter={x:Static c:IntConverters.IsGreaterThanZero}}">
      <TextBlock Text="Double-click to open in browser"
                 FontSize="10"
                 Foreground="{DynamicResource Brush.FG2}"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"/>
    </Border>

  </Grid>
</UserControl>
